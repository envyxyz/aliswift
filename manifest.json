{
  "manifest_version": 3,
  "name": "AliSwift",
  "version": "1.0",
  "description": "1-Click dropshipping scraper. Instantly export AliExpress product data, images, and prices directly to your Google Sheets",
  "permissions": ["storage", "identity", "tabs", "activeTab"],
  "host_permissions": [
    "https://www.aliexpress.com/*",
    "https://www.aliexpress.us/*",
    "https://*.aliexpress.com/*",
    "https://sheets.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon48.png"
  },
  "options_page": "options/options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.aliexpress.com/item/*",
        "https://www.aliexpress.us/item/*",
        "https://*.aliexpress.com/item/*",
        "https://www.aliexpress.com/*/buyNow*",
        "https://www.aliexpress.us/*/buyNow*"
      ],
      "js": ["content.js"]
    }
  ],
  "oauth2": {
    "client_id": "969152943077-1qkbqj3sdfoehcuqog2bns9mt5a24l0q.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/spreadsheets"]
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://www.aliexpress.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
